---
/* src/components/Footer.astro */
import { useTranslations } from "../i18n/utils";

export interface Props {
  htmlLang: "en" | "zh-TW";
}

const { htmlLang } = Astro.props;
const lang = htmlLang === "en" ? "en" : "zh-tw";
const t = useTranslations(lang);
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-left">
      <span>{t("footer.copyright").replace("{year}", new Date().getFullYear().toString())}</span>
      <span class="footer-bottom-links">
        {
          htmlLang === "en" ? (
            <>
              <span class="separator">|</span> <a href="/en/about">About</a>
              <span class="separator">|</span> <a href="/en/contact">Contact Us</a>
              <span class="separator">|</span> <a href="/en/privacy" rel="noopener noreferrer">Privacy Policy</a>
              <span class="separator">|</span> <a href="/en/disclaimer">Disclaimer</a>
            </>
          ) : (
            <>
              <span class="separator">|</span> <a href="/about">關於本站</a>
              <span class="separator">|</span> <a href="/contact">聯絡我們</a>
              <span class="separator">|</span> <a href="/privacy" rel="noopener noreferrer">隱私權政策</a>
              <span class="separator">|</span> <a href="/disclaimer">免責聲明</a>
            </>
          )
        }
      </span>
    </div>

    <div class="footer-center">
    </div>

    <div class="footer-right">
      <button type="button" class="footer-privacy-link" id="privacy-toggle">
        {htmlLang === 'en' ? 'Cookie Settings' : 'Cookie 設定'}
      </button>
    </div>
  </div>
</footer>

<script is:inline>
  (function () {
    // 將 Footer 的 Cookie 設定按鈕連結到 CookieConsent 面板（透過 CustomEvent 解耦）
    var btn = document.getElementById('privacy-toggle');
    if (btn) {
      btn.addEventListener('click', function () {
        document.dispatchEvent(new CustomEvent('open-privacy-panel'));
      });
    }
  })();
</script>

<style is:global>
  .site-footer {
    margin-top: 3rem;
    padding: 1.5rem 1.5rem 2.5rem 1.5rem;
    border-top: 1px solid rgba(0, 0, 0, 0.05);
    font-size: 0.9rem;
    color: #777;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .footer-left {
    flex: 2;
    text-align: left;
    display: flex;
    align-items: center;
    flex-wrap: nowrap;
    gap: 4px;
    white-space: nowrap;
  }

  .footer-right {
    flex: 1;
    text-align: right;
  }

  .footer-bottom-links {
    margin-left: 8px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
  }

  .footer-bottom-links a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-bottom-links a:hover {
    color: var(--primary-red);
  }

  .separator {
    opacity: 0.5;
    font-size: 0.85rem;
  }

  .footer-center {
    flex: 2;
    text-align: center;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    color: #555;
    font-weight: 500;
  }

  .footer-divider {
    margin: 0 0.5rem;
    color: #ccc;
  }

  @media (max-width: 768px) {
    .footer-inner { flex-direction: column; gap: 0.8rem; text-align: center; }
    .footer-left, .footer-right, .footer-center { flex: none; width: 100%; text-align: center; }
    .footer-center { flex-direction: column; gap: 0.3rem; }
    .footer-divider { display: none; }
  }

  .footer-privacy-link {
    border: 1px solid rgba(184, 92, 77, 0.2);
    background: rgba(255, 255, 255, 0.6);
    color: #b85c4d;
    font-weight: 700;
    cursor: pointer;
    padding: 5px 14px;
    border-radius: 99px;
    font-size: 0.8rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: inline-flex;
    align-items: center;
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.05);
  }
  .footer-privacy-link:hover { background: #b85c4d; color: #ffffff; }
</style>
