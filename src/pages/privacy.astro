---
/* src/pages/privacy.astro */
import BaseLayout from "../layouts/BaseLayout.astro";
import AboutSidebar from "../components/AboutSidebar.astro";
import { useTranslations } from "../i18n/utils";

const t = useTranslations('zh-tw');
const currentPath = Astro.url.pathname;
const siteUrl = Astro.site ? Astro.site.toString().replace(/\/$/, '') : 'https://blog.ouoxo.com';
const pageUrl = new URL(currentPath, siteUrl).href;
---

<BaseLayout title="隱私權政策">
  <script type="application/ld+json" set:html={`
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "隱私權政策",
      "url": ${JSON.stringify(pageUrl)},
      "description": "本站隱私權政策，說明資料收集與處理方式。",
      "publisher": {
        "@type": "Organization",
        "name": "夈似"
      }
    }
  `} />
  <div class="page-container" style="margin-top: 2rem;">
    <div class="content-wrapper">
      <AboutSidebar currentPath={currentPath} lang="zh-tw" />
      <main class="main-content">
        <article class="glass-card post-article-body" style="padding: 2.5rem;">
          <div class="markdown-content about-enhanced">
            <h2>隱私權政策</h2>
            <p>本站承諾保護使用者的隱私。以下內容說明本站處理使用者資料的相關政策：</p>
            
            <h3>資訊收集</h3>
            <ul>
              <li><strong>資訊收集：</strong> 本站為採用 Astro 架構的靜態網站。我們不會在伺服器端主動收集、儲存或追蹤使用者的個人識別資訊、IP 位址或瀏覽紀錄。</li>
              <li><strong>流量統計 (Google Analytics)：</strong> 本站使用 Google Analytics (GA4) 收集匿名流量資訊，以協助我們了解網站使用情況並優化內容。這些數據皆為匿名化處理，不包含個人可識別身分資訊。</li>
              <li>您可透過本頁下方的「您的隱私選擇」面板，自主選擇是否允許 Google Analytics 收集瀏覽數據。若您關閉此選項，GA4 追蹤碼將不會被載入。</li>
              <li><strong>時區檢測：</strong> 首頁時鐘使用瀏覽器內建的時區資訊，或用戶手動選擇時區。選擇的時區儲存在本地儲存中。</li>
            </ul>

            <h3>廣告與 Cookie 聲明</h3>
            <ul>
              <li>本站使用 Google AdSense 投放廣告。Google 作為第三方供應商，會使用 Cookie 根據您在本站及網路其他位置的訪問紀錄來投放廣告。</li>
              <li>您可以透過訪問 <a href="https://www.google.com/settings/ads" target="_blank" rel="noopener noreferrer">Google 廣告設定</a> 頁面，來管理或停用個人化廣告。</li>
            </ul>

            <h3>本機儲存</h3>
            <ul>
              <li><strong>本機儲存與隱私設定：</strong> 本站使用 LocalStorage 記住您選擇的時區設定。您可以在本頁下方的隱私設定中選擇是否允許本站記住此設定：
                <ul>
                  <li><strong>允許記住時區設定</strong>：打開此選項後，您選擇的時區會儲存在本機，下次訪問時會自動載入。</li>
                  <li><strong>不允許記住時區設定</strong>：關閉此選項後，時區選擇不會被儲存，每次訪問時都會重置為預設值。</li>
                </ul>
              </li>
            </ul>

            <h3>隱私設定面板</h3>
            <div id="privacy-settings-panel" style="border: 1px solid #ddd; padding: 1rem; border-radius: 8px; background-color: #f9f9f9; margin: 1rem 0;">
              <h4 style="margin-top: 0;">您的隱私選擇</h4>
              <label style="display: flex; align-items: center; margin-bottom: 1rem; cursor: pointer;">
                <input type="checkbox" id="remember-timezone-toggle" style="margin-right: 0.5rem; width: 18px; height: 18px; cursor: pointer; accent-color: #b85c4d;" />
                <span>允許本站記住我選擇的時區設定</span>
              </label>
              <label style="display: flex; align-items: center; margin-bottom: 1rem; cursor: pointer;">
                <input type="checkbox" id="enable-analytics-toggle" style="margin-right: 0.5rem; width: 18px; height: 18px; cursor: pointer; accent-color: #b85c4d;" />
                <span>允許 Google Analytics (GA4) 收集瀏覽數據進行網站分析</span>
              </label>
              <p style="font-size: 0.9rem; color: #666;">您的設定會在按下「儲存設定」後生效。關閉 GA4 後將在頁面重新載入時生效。</p>
              <button type="button" id="privacy-save-inline" style="padding: 0.4rem 1.2rem; border-radius: 999px; border: none; background: #b85c4d; color: #fff; font-weight: 600; cursor: pointer;">儲存設定</button>
            </div>
          </div>
        </article>
      </main>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  // 初始化隱私設定面板（同步 BaseLayout 中的設定）
  var settings = window.__privacySettings || { rememberTimezone: true, enableAnalytics: true, hasSetCookies: false };

  var tzToggle = document.getElementById('remember-timezone-toggle');
  var gaToggle = document.getElementById('enable-analytics-toggle');
  var saveBtn = document.getElementById('privacy-save-inline');

  if (tzToggle) tzToggle.checked = settings.hasSetCookies ? (settings.rememberTimezone !== false) : true;
  if (gaToggle) gaToggle.checked = settings.hasSetCookies ? (settings.enableAnalytics !== false) : true;

  if (saveBtn) {
    saveBtn.addEventListener('click', function() {
      if (typeof window.updatePrivacySettings === 'function') {
        var tzChecked = tzToggle ? tzToggle.checked : true;
        var gaChecked = gaToggle ? gaToggle.checked : true;
        window.updatePrivacySettings({
          hasSetCookies: true,
          rememberTimezone: tzChecked,
          enableAnalytics: gaChecked
        });
        if (!tzChecked) {
          try { localStorage.removeItem('selectedTimezone'); } catch(e) {}
        }
        // 重新載入以套用新的 GA 設定
        window.location.reload();
      }
    });
  }
</script>
