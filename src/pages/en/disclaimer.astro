---
/* src/pages/en/disclaimer.astro */
import BaseLayout from "../../layouts/BaseLayout.astro";
import AboutSidebar from "../../components/AboutSidebar.astro";
import { useTranslations } from "../../i18n/utils";

const t = useTranslations('en');
const currentPath = Astro.url.pathname;
const siteUrl = Astro.site ? Astro.site.toString().replace(/\/$/, '') : 'https://example.com';
const pageUrl = new URL(currentPath, siteUrl).href;
---

<BaseLayout title="Disclaimer">
  <script type="application/ld+json" set:html={`
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "Disclaimer",
      "url": ${JSON.stringify(pageUrl)},
      "description": "Disclaimer and legal information.",
      "publisher": {
        "@type": "Organization",
        "name": "My Blog"
      }
    }
  `} />
  <div class="page-container" style="margin-top: 2rem;">
    <div class="content-wrapper">
      <AboutSidebar currentPath={currentPath} lang="en" />
      <main class="main-content">
        <article class="glass-card post-article-body" style="padding: 2.5rem;">
          <div class="markdown-content about-enhanced">
            <h2>Disclaimer</h2>
            <p>Please enter your disclaimer here.</p>
            <p>You can edit this text in the <code>src/pages/en/disclaimer.astro</code> file.</p>
          </div>
        </article>
      </main>
    </div>
  </div>
</BaseLayout>
