---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<BaseLayout title="404 - Page Not Found">
  <div class="error-container">
    <div class="glass-error-card">
      <h1 class="error-code">404</h1>
      <div class="error-divider"></div>
      <h2 class="error-message">
        {lang === 'en' ? 'Oops! Page Not Found' : '噢！找不到這個頁面'}
      </h2>
      <p class="error-desc">
        {lang === 'en' 
          ? "The page you are looking for might have been removed or is temporarily unavailable." 
          : "您要找的頁面可能已被移除、更改名稱，或是暫時無法使用。"}
      </p>
      <a href={translatePath('/')} class="back-home-btn">
        {lang === 'en' ? 'Back to Home' : '返回首頁'}
      </a>
    </div>
  </div>
</BaseLayout>

<style>
  .error-container {
    height: 80vh;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 0 1.5rem;
  }

  .glass-error-card {
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 30px;
    padding: 4rem 3rem;
    text-align: center;
    max-width: 500px;
    width: 100%;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.08);
  }

  .error-code {
    font-size: 6rem;
    font-weight: 950;
    color: #b85c4d;
    line-height: 1;
    margin: 0;
    letter-spacing: -2px;
  }

  .error-divider {
    width: 40px;
    height: 4px;
    background: #b85c4d;
    margin: 1.5rem auto;
    border-radius: 2px;
    opacity: 0.3;
  }

  .error-message {
    font-size: 1.8rem;
    font-weight: 800;
    color: #2d2d2d;
    margin-bottom: 1rem;
  }

  .error-desc {
    color: #666;
    line-height: 1.6;
    margin-bottom: 2.5rem;
  }

  .back-home-btn {
    display: inline-block;
    padding: 1rem 2.5rem;
    background: #b85c4d;
    color: white;
    text-decoration: none;
    border-radius: 14px;
    font-weight: 700;
    box-shadow: 0 10px 20px -5px rgba(184, 92, 77, 0.4);
    transition: all 0.3s;
  }

  .back-home-btn:hover {
    transform: translateY(-3px);
    filter: brightness(1.1);
    box-shadow: 0 15px 30px -5px rgba(184, 92, 77, 0.5);
  }

  @media (max-width: 480px) {
    .error-code { font-size: 4rem; }
    .error-message { font-size: 1.4rem; }
  }
</style>
