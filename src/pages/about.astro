---
/* src/pages/about.astro */
import BaseLayout from "../layouts/BaseLayout.astro";
import AboutSidebar from "../components/AboutSidebar.astro";
import { useTranslations } from "../i18n/utils";

const t = useTranslations("zh-tw");
const currentPath = Astro.url.pathname;
const siteUrl = Astro.site
  ? Astro.site.toString().replace(/\/$/, "")
  : "https://example.com";
const pageUrl = new URL(currentPath, siteUrl).href;
---

<BaseLayout title="關於我">
  <script
    type="application/ld+json"
    set:html={`
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "關於我",
      "url": ${JSON.stringify(pageUrl)},
      "description": "關於本站作者的介紹。",
      "publisher": {
        "@type": "Organization",
        "name": "My Blog"
      }
    }
  `}
  />
  <div class="page-container" style="margin-top: 2rem;">
    <div class="content-wrapper">
      <AboutSidebar currentPath={currentPath} lang="zh-tw" />
      <main class="main-content">
        <article class="glass-card post-article-body" style="padding: 2.5rem;">
          <div class="markdown-content about-enhanced">
            <h2>關於本站 (About)</h2>
            <p>
              請在這裡輸入你的個人介紹。<br />
              你可以在 <code>src/pages/about.astro</code> 檔案中修改這些文字。
            </p>
          </div>
        </article>
      </main>
    </div>
  </div>
</BaseLayout>
