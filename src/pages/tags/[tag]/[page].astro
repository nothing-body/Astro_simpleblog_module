---
/* src/pages/tags/[tag]/[page].astro */
import { getCollection } from 'astro:content';
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Sidebar from "../../../components/Sidebar.astro";
import PostCard from "../../../components/PostCard.astro";
import Pagination from "../../../components/Pagination.astro";
import type { PaginateFunction } from 'astro';

// 靜態模式：build 時為每個標籤的每一頁產生靜態 HTML
export async function getStaticPaths({ paginate }: { paginate: PaginateFunction }) {
  const allPosts = await getCollection('blog', ({ id }) => id.startsWith('zh-tw/'));
  const tags = [...new Set(allPosts.map(p => p.data.tags).flat())];

  return tags.flatMap((t) => {
    const filtered = allPosts
      .filter(p => p.data.tags.includes(t))
      .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
    
    return paginate(filtered, { 
      params: { tag: t.toString() }, 
      pageSize: 10 
    });
  });
}

const { page } = Astro.props;
const { tag } = Astro.params;
// 重新讀取全站數據以供 Sidebar 組件使用
const allPosts = await getCollection('blog', ({ id }) => id.startsWith('zh-tw/'));

const totalPages = page.lastPage || 1;
const pageNumbers = Array.from({ length: totalPages }, (_, i) => i + 1);
---

<BaseLayout title={`標籤：#${tag} - 第 ${page.currentPage} 頁`}>
  <div class="page-container">
    <div class="content-wrapper">
      <Sidebar allPosts={allPosts} lang="zh-tw" activeTag={tag} />

      <main class="main-content">
        <h2 style="font-size: 1.6rem; font-weight: 800; margin-bottom: 0.6rem;">標籤：#{tag} (第 {page.currentPage} 頁)</h2>
        <hr class="page-divider" />
        
        {page.data.map((post: any) => <PostCard post={post} lang="zh-tw" />)}

        <Pagination 
          currentPage={page.currentPage} 
          totalPages={totalPages} 
          prevUrl={page.url.prev} 
          nextUrl={page.url.next} 
          getPageUrl={(num) => `/tags/${tag}/${num}`} 
        />
      </main>
    </div>
  </div>
</BaseLayout>


